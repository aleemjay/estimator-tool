# Copy to .env and fill in from your APS app at https://aps.autodesk.com/myapps
APS_CLIENT_ID=
APS_CLIENT_SECRET=
# Must match the Callback URL configured on the APS app exactly
APS_CALLBACK_URL=http://localhost:8787/callback

# Email intake (Google Workspace via IMAP)
# App password: https://myaccount.google.com/apppasswords (needs 2-step verification)
IMAP_USER=contact@epoxycreationsfl.com
IMAP_APP_PASSWORD=
