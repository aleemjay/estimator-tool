# Copy to .env and fill in from your APS app at https://aps.autodesk.com/myapps
APS_CLIENT_ID=
APS_CLIENT_SECRET=
# Must match the Callback URL configured on the APS app exactly
APS_CALLBACK_URL=http://localhost:8787/callback

# Email intake (Outlook / Microsoft 365 via Microsoft Graph)
# From the Entra app registration (see README "Email intake setup")
MS_CLIENT_ID=
# Directory (tenant) ID; leave blank to default to "organizations"
MS_TENANT_ID=
